github_owner            = "YOUR_GITHUB_ORG_OR_USER"
github_repo             = "YOUR_REPO"
manager_github_username = "manager-github-login"
protected_branch        = "main"

# Start empty for first bootstrap if checks do not exist yet.
# After the first workflow run, add exact check names.
required_status_check_contexts = []

require_code_owner_reviews = true

# 3 hours before production deployment job can proceed.
production_wait_timer_minutes = 180

# Set to true if production requires a second manager approval after the 3-hour wait.
require_production_environment_review = false
